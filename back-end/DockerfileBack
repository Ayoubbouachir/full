# ----------- Build stage ----------
FROM node:18-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# Build NestJS
RUN npm run build


# ----------- Production stage ----------
FROM node:18-alpine

WORKDIR /app

# Copy only needed files
COPY package*.json ./
RUN npm install --omit=dev

COPY --from=build /app/dist ./dist

# Expose Nest port
EXPOSE 3000

# Start app
CMD ["node", "dist/main.js"]
